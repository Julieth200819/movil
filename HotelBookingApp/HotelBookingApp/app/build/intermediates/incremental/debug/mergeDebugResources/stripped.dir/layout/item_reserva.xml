<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvReservaId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reserva #123"
                android:textSize="13sp"
                android:textColor="#757575"/>

            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRMADA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#E8F5E9"
                android:padding="6dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvHotelNombre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hotel Boutique Andino"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvFechas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 2024-01-10 → 2024-01-13"
            android:textSize="13sp"
            android:textColor="#424242"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTipoHab"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛏 Suite"
                android:textSize="13sp"
                android:textColor="#5C6BC0"/>

            <TextView
                android:id="@+id/tvHuespedes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 2 huéspedes"
                android:textSize="13sp"
                android:textColor="#5C6BC0"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
